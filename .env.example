# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=newsdb
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=change-me  # Required — no default; startup fails if missing

# API Configuration
API_PORT=5000          # Port inside the container
HOST_PORT=5000         # Port exposed on the host (change to 80 for production)

# Security (optional — leave unset for local development)
# API_KEY=your-secret-key-here          # Enables X-API-Key auth on write endpoints
# CORS_ORIGINS=https://yourapp.com      # Comma-separated allowed origins (default: *)
# TRUSTED_PROXY_COUNT=1                  # Reverse proxies in front (rate-limit reads
#                                        # client IP from X-Forwarded-For). 0 = direct.
# LOG_FORMAT=json                        # 'text' (default, human-readable) or 'json'

# Scraper proxy (recommended — Google blocks automated browsers from /search
# without a residential/mobile proxy). Setting this enables proxying and
# overrides the proxies list in config.yml. No rebuild needed.
# Format: scheme://[user:pass@]host:port   (http, https, or socks5)
# SCRAPER_PROXY=http://user:pass@gateway.provider.com:7777

# NOTE: tuning knobs (DB pool/conn, rate limiting, feed page size, scrape-health
# thresholds, DB retry, frontend poll/WS cadence) live in config.yml —
# the preferred surface. Any of them can ALSO be set here (env wins), but this
# file is reserved for secrets and values Docker/compose need at startup.

